# OpenAI API
OPENAI_API_KEY=your_openai_api_key_here

# Tavily API
TAVILY_API_KEY=your_tavily_api_key_here

# Serper API
SERPER_API_KEY=your_serper_api_key_here

# ChainGPT API
CHAINGPT_API_KEY=your_chaingpt_api_key_here

# Wallet Configuration
WALLET_ADDRESS=your_wallet_address_here
NEXT_PUBLIC_WALLET_ADDRESS=your_wallet_address_here
PRIVATE_KEY=your_private_key_here
NEXT_PUBLIC_PRIVATE_KEY=your_private_key_here

# Privy Configuration
NEXT_PUBLIC_PRIVY_APP_ID=your_privy_app_id_here
PRIVY_APP_SECRET=your_privy_app_secret_here
PRIVY_SIGNING_KEY=your_privy_signing_key_here

# Chat History
ENABLE_SAVE_CHAT_HISTORY=false
NEXT_PUBLIC_ENABLE_SAVE_CHAT_HISTORY=false

# Redis Configuration
USE_LOCAL_REDIS=true
LOCAL_REDIS_URL=redis://localhost:6379

# Ethereum Configuration
ETH_RPC_URL=your_eth_rpc_url_here
NEXT_PUBLIC_TEST_NET_ENV=testnet
ALCHEMY_API_KEY=your_alchemy_api_key_here

# Enso API
ENSO_API_KEY=your_enso_api_key_here
NEXT_PUBLIC_ENSO_API_KEY=your_enso_api_key_here

# Tenderly API (for transaction simulation)
TENDERLY_API_KEY=your_tenderly_api_key_here
TENDERLY_ACCOUNT_ID=your_tenderly_account_id_here
TENDERLY_PROJECT_ID=your_tenderly_project_id_here

# Twitter API Configuration
TWITTER_API_BEARER_TOKEN=your_bearer_token
TWITTER_API_KEY=your_api_key
TWITTER_API_SECRET=your_api_secret
TWITTER_ACCESS_TOKEN=your_access_token
TWITTER_ACCESS_TOKEN_SECRET=your_access_token_secret
TWITTER_USER_ID=your_jarvis_user_id_optional

# Twitter Bot Service Toggle (set to 'true' to enable, prevents multi-instance conflicts)
ENABLE_TWITTER_BOT=true
